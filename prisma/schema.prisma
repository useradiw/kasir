generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Category {
  id        String     @id @default(uuid())
  name      String
  sortOrder Int        @default(0)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  menuItems MenuItem[]

  @@map("categories")
}

model MenuItem {
  id           String        @id @default(uuid())
  name         String
  categoryId   String
  price        Int
  isHidden     Boolean       @default(false)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  category     Category      @relation(fields: [categoryId], references: [id])
  variants     MenuVariant[]
  packageItems PackageItem[]
  orderItems   OrderItem[]

  @@map("menu_items")
}

model MenuVariant {
  id            String        @id @default(uuid())
  menuItemId    String
  label         String
  priceModifier Int           @default(0)
  menuItem      MenuItem      @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  orderItems    OrderItem[]
  packageItems  PackageItem[]

  @@map("menu_variants")
}

model Package {
  id           String        @id @default(uuid())
  name         String
  bundlePrice  Int
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  packageItems PackageItem[]
  orderItems   OrderItem[]

  @@map("packages")
}

model PackageItem {
  id           String       @id @default(uuid())
  packageId    String
  menuItemId   String
  variantId    String?
  nameSnapshot String
  package      Package      @relation(fields: [packageId], references: [id], onDelete: Cascade)
  menuItem     MenuItem     @relation(fields: [menuItemId], references: [id])
  variant      MenuVariant? @relation(fields: [variantId], references: [id])

  @@unique([packageId, menuItemId, variantId])
  @@map("package_items")
}

// --- ORDERING & SESSIONS ---

model TableSession {
  id            String        @id @default(uuid())
  name          String
  service       ServiceEnum?
  customerAlias String?
  customerPhone String?
  ownerId       String?
  orderedAt     DateTime?
  servedAt      DateTime?
  paidAt        DateTime?
  erasedAt      DateTime?
  createdAt     DateTime      @default(now())
  owner         Staff?        @relation(fields: [ownerId], references: [id], onDelete: SetNull)
  orderItems    OrderItem[]
  transactions  Transaction[]

  @@map("table_sessions")
}

model OrderItem {
  id             String          @id @default(uuid())
  tableSessionId String
  menuItemId     String?
  packageId      String?
  variantId      String?
  qty            Int             @default(1)
  note           String?
  status         OrderItemStatus @default(PENDING)
  nameSnapshot   String
  price          Int
  preparedAt     DateTime?
  servedAt       DateTime?
  cancelledAt    DateTime?
  createdAt      DateTime        @default(now())
  tableSession   TableSession    @relation(fields: [tableSessionId], references: [id], onDelete: Cascade)
  menuItem       MenuItem?       @relation(fields: [menuItemId], references: [id])
  package        Package?        @relation(fields: [packageId], references: [id])
  variant        MenuVariant?    @relation(fields: [variantId], references: [id])

  @@map("order_items")
}

// --- FINANCE & TRANSACTIONS ---

model Transaction {
  id             String            @id @default(uuid())
  tableSessionId String
  processedById  String
  subtotal       Int
  taxAmount      Int               @default(0)
  serviceCharge  Int               @default(0)
  discountAmount Int               @default(0)
  totalAmount    Int
  cashAmount     Int               @default(0)
  qrisAmount     Int               @default(0)
  paymentMethod  PaymentMethod
  status         TransactionStatus @default(PAID)
  voidedById     String?
  voidedAt       DateTime?
  voidReason     String?
  paidAt         DateTime          @default(now())
  createdAt      DateTime          @default(now())
  tableSession   TableSession      @relation(fields: [tableSessionId], references: [id])
  processedBy    Staff             @relation("ProcessedTransactions", fields: [processedById], references: [id])
  voidedBy       Staff?            @relation("VoidedTransactions", fields: [voidedById], references: [id], onDelete: SetNull)

  @@map("transactions")
}

model Expense {
  id             String        @id @default(uuid())
  description    String?
  recordedAt     DateTime      @default(now())
  createdAt      DateTime      @default(now())
  staffId        String?
  deductFromCash Boolean       @default(true)
  staff          Staff?        @relation(fields: [staffId], references: [id])
  items          ExpenseItem[]

  @@map("expenses")
}

model ExpenseItem {
  id          String  @id @default(uuid())
  expenseId   String
  expense     Expense @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  description String
  amount      Int
  cost        Int

  @@map("expense_items")
}

model CashRegister {
  id          String   @id @default(uuid())
  date        DateTime @unique
  openingCash Int      @default(0)
  closingCash Int?
  openedById  String?
  closedById  String?
  editedById  String?
  editedAt    DateTime?
  openedBy    Staff?   @relation("OpenedRegisters", fields: [openedById], references: [id])
  closedBy    Staff?   @relation("ClosedRegisters", fields: [closedById], references: [id])
  editedBy    Staff?   @relation("EditedRegisters", fields: [editedById], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("cash_registers")
}

// --- SETTINGS ---

model Setting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt

  @@map("settings")
}

// --- STAFF & ATTENDANCE ---

model Staff {
  id                String             @id @default(uuid())
  username          String?            @unique
  name              String
  role              RoleEnum
  isActive          Boolean            @default(true)
  supabaseUserId    String?            @unique
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  attendanceRecords   AttendanceRecord[]
  transactions        Transaction[]      @relation("ProcessedTransactions")
  voidedTransactions  Transaction[]      @relation("VoidedTransactions")
  tableSessions       TableSession[]
  openedRegisters     CashRegister[]     @relation("OpenedRegisters")
  closedRegisters     CashRegister[]     @relation("ClosedRegisters")
  editedRegisters     CashRegister[]     @relation("EditedRegisters")
  expenses            Expense[]

  @@map("staff")
}

model AttendanceRecord {
  id       String           @id @default(uuid())
  staffId  String
  date     DateTime
  status   AttendanceStatus
  markedAt DateTime         @default(now())
  staff    Staff            @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@unique([staffId, date])
  @@map("attendance_records")
}

// --- ENUMS ---

enum ServiceEnum {
  GoFood
  ShopeeFood
  GrabFood
  Take_Away
  Unknown
}

enum OrderItemStatus {
  PENDING
  PREPARING
  SERVED
  CANCELLED
}

enum PaymentMethod {
  CASH
  QRIS
}

enum TransactionStatus {
  PAID
  VOIDED
}

enum RoleEnum {
  OWNER
  MANAGER
  CASHIER
  STAFF
}

enum AttendanceStatus {
  PRESENT
  ABSENT
}
