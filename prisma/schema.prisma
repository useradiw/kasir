generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Category {
  id        String     @id @default(uuid())
  name      String
  sortOrder Int        @default(0)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  menuItems MenuItem[]

  @@map("categories")
}

model MenuItem {
  id           String                @id @default(uuid())
  name         String
  categoryId   String
  price        Int
  isHidden     Boolean               @default(false)
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt
  category     Category              @relation(fields: [categoryId], references: [id])
  variants     MenuVariant[]
  packageItems PackageItem[]
  orderItems   OrderItem[]
  onlinePrices MenuItemOnlinePrice[]
  recipes      Recipe[]

  @@map("menu_items")
}

model MenuVariant {
  id            String                @id @default(uuid())
  menuItemId    String
  label         String
  priceModifier Int                   @default(0)
  menuItem      MenuItem              @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  orderItems    OrderItem[]
  packageItems  PackageItem[]
  onlinePrices  MenuItemOnlinePrice[]
  recipes       Recipe[]

  @@map("menu_variants")
}

model Package {
  id           String        @id @default(uuid())
  name         String
  bundlePrice  Int
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  packageItems PackageItem[]
  orderItems   OrderItem[]

  @@map("packages")
}

model PackageItem {
  id           String       @id @default(uuid())
  packageId    String
  menuItemId   String
  variantId    String?
  nameSnapshot String
  package      Package      @relation(fields: [packageId], references: [id], onDelete: Cascade)
  menuItem     MenuItem     @relation(fields: [menuItemId], references: [id])
  variant      MenuVariant? @relation(fields: [variantId], references: [id])

  @@unique([packageId, menuItemId, variantId])
  @@map("package_items")
}

// --- ORDERING & SESSIONS ---

model TableSession {
  id              String        @id @default(uuid())
  name            String
  service         ServiceEnum?
  externalOrderId String?
  customerAlias   String?
  customerPhone   String?
  ownerId         String?
  orderedAt       DateTime?
  servedAt        DateTime?
  paidAt          DateTime?
  erasedAt        DateTime?
  createdAt       DateTime      @default(now())
  owner           Staff?        @relation(fields: [ownerId], references: [id], onDelete: SetNull)
  orderItems      OrderItem[]
  transactions    Transaction[]

  @@map("table_sessions")
}

model OrderItem {
  id             String          @id @default(uuid())
  tableSessionId String
  menuItemId     String?
  packageId      String?
  variantId      String?
  qty            Int             @default(1)
  note           String?
  status         OrderItemStatus @default(PENDING)
  nameSnapshot   String
  price          Int
  splitGroup     Int             @default(0)
  preparedAt     DateTime?
  servedAt       DateTime?
  cancelledAt    DateTime?
  createdAt      DateTime        @default(now())
  tableSession   TableSession    @relation(fields: [tableSessionId], references: [id], onDelete: Cascade)
  menuItem       MenuItem?       @relation(fields: [menuItemId], references: [id])
  package        Package?        @relation(fields: [packageId], references: [id])
  variant        MenuVariant?    @relation(fields: [variantId], references: [id])

  @@map("order_items")
}

// --- FINANCE & TRANSACTIONS ---

model Transaction {
  id             String            @id @default(uuid())
  tableSessionId String
  processedById  String
  subtotal       Int
  taxAmount      Int               @default(0)
  serviceCharge  Int               @default(0)
  discountAmount Int               @default(0)
  totalAmount    Int
  cashAmount     Int               @default(0)
  qrisAmount     Int               @default(0)
  paymentMethod  PaymentMethod
  splitGroup     Int               @default(0)
  status         TransactionStatus @default(PAID)
  voidedById     String?
  voidedAt       DateTime?
  voidReason     String?
  paidAt         DateTime          @default(now())
  createdAt      DateTime          @default(now())
  tableSession   TableSession      @relation(fields: [tableSessionId], references: [id])
  processedBy    Staff             @relation("ProcessedTransactions", fields: [processedById], references: [id])
  voidedBy       Staff?            @relation("VoidedTransactions", fields: [voidedById], references: [id], onDelete: SetNull)
  cogs           Int?
  settlementItem SettlementItem?

  @@map("transactions")
}

model Expense {
  id               String        @id @default(uuid())
  description      String?
  recordedAt       DateTime      @default(now())
  createdAt        DateTime      @default(now())
  staffId          String?
  deductFromCash   Boolean       @default(true)
  countToKasPakHar Boolean       @default(false)
  staff            Staff?        @relation(fields: [staffId], references: [id])
  items            ExpenseItem[]
  kasPakHarEntries KasPakHar[]

  @@map("expenses")
}

model ExpenseItem {
  id          String           @id @default(uuid())
  expenseId   String
  expense     Expense          @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  description String
  amount      Float
  cost        Int
  unit        String?
  templateId  String?
  template    ExpenseTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)

  @@map("expense_items")
}

model CashRegister {
  id          String   @id @default(uuid())
  date        DateTime @unique
  openingCash Int      @default(0)
  closingCash Int?
  openedById  String?
  closedById  String?
  editedById  String?
  editedAt    DateTime?
  openedBy    Staff?   @relation("OpenedRegisters", fields: [openedById], references: [id])
  closedBy    Staff?   @relation("ClosedRegisters", fields: [closedById], references: [id])
  editedBy    Staff?   @relation("EditedRegisters", fields: [editedById], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("cash_registers")
}

// --- SETTINGS ---

model Setting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt

  @@map("settings")
}

// --- STAFF & ATTENDANCE ---

model Staff {
  id                String             @id @default(uuid())
  username          String?            @unique
  name              String
  role              RoleEnum
  isActive          Boolean            @default(true)
  supabaseUserId    String?            @unique
  salary            Int?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  attendanceRecords   AttendanceRecord[]
  transactions        Transaction[]      @relation("ProcessedTransactions")
  voidedTransactions  Transaction[]      @relation("VoidedTransactions")
  tableSessions       TableSession[]
  openedRegisters     CashRegister[]     @relation("OpenedRegisters")
  closedRegisters     CashRegister[]     @relation("ClosedRegisters")
  editedRegisters     CashRegister[]     @relation("EditedRegisters")
  expenses            Expense[]
  notifications       Notification[]
  kasPakHarEntries    KasPakHar[]
  onlineSettlements   OnlineSettlement[] @relation("SettledOnlineOrders")

  @@map("staff")
}

model Notification {
  id          String           @id @default(cuid())
  recipientId String
  type        NotificationType
  title       String
  body        String
  metadata    Json?
  readAt      DateTime?
  createdAt   DateTime         @default(now())
  recipient   Staff            @relation(fields: [recipientId], references: [id], onDelete: Cascade)

  @@index([recipientId, readAt, createdAt])
  @@map("notifications")
}

model AttendanceRecord {
  id       String           @id @default(uuid())
  staffId  String
  date     DateTime
  status   AttendanceStatus
  markedAt DateTime         @default(now())
  staff    Staff            @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@unique([staffId, date])
  @@map("attendance_records")
}

// --- KAS PAK HAR ---

model KasPakHar {
  id          String        @id @default(uuid())
  date        DateTime      @default(now())
  type        KasPakHarType
  amount      Int
  description String?
  expenseId   String?
  expense     Expense?      @relation(fields: [expenseId], references: [id], onDelete: SetNull)
  createdById String?
  createdBy   Staff?        @relation(fields: [createdById], references: [id], onDelete: SetNull)
  createdAt   DateTime      @default(now())

  @@map("kas_pak_har")
}

// --- ONLINE PRICING ---

model MenuItemOnlinePrice {
  id         String       @id @default(uuid())
  menuItemId String
  variantId  String?
  service    ServiceEnum
  price      Int
  menuItem   MenuItem     @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  variant    MenuVariant? @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@unique([menuItemId, variantId, service])
  @@map("menu_item_online_prices")
}

// --- ONLINE SETTLEMENT ---

model OnlineSettlement {
  id               String                @id @default(uuid())
  service          ServiceEnum
  settlementDate   DateTime              @default(now())
  totalGross       Int
  commissionAmount Int
  finalAmount      Int
  settledById      String
  notes            String?
  createdAt        DateTime              @default(now())
  settledBy        Staff                 @relation("SettledOnlineOrders", fields: [settledById], references: [id])
  items            SettlementItem[]
  deductions       SettlementDeduction[]

  @@index([service, settlementDate])
  @@map("online_settlements")
}

model SettlementItem {
  id            String           @id @default(uuid())
  settlementId  String
  transactionId String           @unique
  settlement    OnlineSettlement @relation(fields: [settlementId], references: [id], onDelete: Cascade)
  transaction   Transaction      @relation(fields: [transactionId], references: [id])

  @@map("settlement_items")
}

model SettlementDeduction {
  id           String           @id @default(uuid())
  settlementId String
  label        String
  amount       Int
  settlement   OnlineSettlement @relation(fields: [settlementId], references: [id], onDelete: Cascade)

  @@map("settlement_deductions")
}

// --- EXPENSE TEMPLATES ---

model ExpenseTemplate {
  id                String             @id @default(uuid())
  name              String             @unique
  defaultUnit       String?
  defaultCost       Int?
  isActive          Boolean            @default(true)
  currentStock      Float              @default(0)
  lowStockAlert     Float?
  createdAt         DateTime           @default(now())
  expenseItems      ExpenseItem[]
  recipeIngredients RecipeIngredient[]
  ingredientLogs    IngredientLog[]

  @@map("expense_templates")
}

// --- RECIPES ---

model Recipe {
  id          String             @id @default(uuid())
  menuItemId  String
  variantId   String?            // null = base item; non-null = specific variant
  notes       String?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  menuItem    MenuItem           @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  variant     MenuVariant?       @relation(fields: [variantId], references: [id], onDelete: Cascade)
  ingredients RecipeIngredient[]

  @@unique([menuItemId, variantId])
  @@map("recipes")
}

model RecipeIngredient {
  id           String           @id @default(uuid())
  recipeId     String
  templateId   String?          // FK to ExpenseTemplate; null = standalone ingredient
  customName   String?          // required when templateId is null
  customUnit   String?
  quantity     Float
  recipe       Recipe           @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  template     ExpenseTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)

  @@map("recipe_ingredients")
}

// --- INGREDIENT STOCK LEDGER ---

model IngredientLog {
  id          String            @id @default(uuid())
  templateId  String
  template    ExpenseTemplate   @relation(fields: [templateId], references: [id], onDelete: Cascade)
  type        StockMovementType
  quantity    Float
  unitCost    Int
  referenceId String?
  note        String?
  createdAt   DateTime          @default(now())

  @@index([templateId, createdAt])
  @@map("ingredient_logs")
}

// --- ENUMS ---

enum ServiceEnum {
  GoFood
  ShopeeFood
  GrabFood
  Take_Away
  Unknown
}

enum OrderItemStatus {
  PENDING
  PREPARING
  SERVED
  CANCELLED
}

enum PaymentMethod {
  CASH
  QRIS
  SPLIT
  PENDING
}

enum TransactionStatus {
  PAID
  VOIDED
}

enum RoleEnum {
  OWNER
  MANAGER
  CASHIER
  STAFF
}

enum AttendanceStatus {
  PRESENT
  ABSENT
}

enum NotificationType {
  TRANSACTION_VOIDED
  SESSION_VOIDED
  TEST
}

enum KasPakHarType {
  DEPOSIT
  WITHDRAWAL
  EXPENSE_DEDUCTION
}

enum StockMovementType {
  PURCHASE
  SALE
  ADJUSTMENT
  WASTE
}
